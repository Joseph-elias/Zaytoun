# Default local dev (active now)
APP_ENV=development
DATABASE_URL=sqlite:///./worker_radar.db

# Optional fallback local URL
DB_FALLBACK_URL=sqlite:///./worker_radar.db
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_TIMEOUT_SECONDS=30
DB_POOL_RECYCLE_SECONDS=1800
CORS_ALLOWED_ORIGINS=http://127.0.0.1:5173,http://localhost:5173,http://127.0.0.1:5500,http://localhost:5500
STARTUP_FAIL_FAST_VALIDATION=true

# Auth
AUTH_SECRET_KEY=change-me-in-production
AUTH_ALGORITHM=HS256
AUTH_CONSENT_VERSION=2026-04-13
AUTH_PASSWORD_RESET_DEV_MODE=false
AUTH_PASSWORD_RESET_CODE_TTL_MINUTES=15
AUTH_PASSWORD_RESET_MAX_ATTEMPTS=5
AUTH_PASSWORD_RESET_EMAIL_ENABLED=false
AUTH_LOGIN_LOCKOUT_ENABLED=true
AUTH_LOGIN_MAX_ATTEMPTS=5
AUTH_LOGIN_LOCKOUT_MINUTES=15
AUTH_MFA_TOTP_ISSUER=Zaytoun
AUTH_MFA_TOTP_DIGITS=6
AUTH_MFA_TOTP_PERIOD_SECONDS=30
AUTH_MFA_TOTP_VALID_WINDOW=1

# SMTP for password reset emails
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_FROM_NAME=Zaytoun
SMTP_USE_TLS=true
SMTP_USE_SSL=false

# Agro Copilot integration (farmer-only proxy)
AGRO_COPILOT_API_BASE_URL=
AGRO_COPILOT_API_KEY=
AGRO_COPILOT_TIMEOUT_SECONDS=120
AGRO_COPILOT_MAX_RETRIES=2
AGRO_COPILOT_RETRY_BACKOFF_MS=300

# HTTP security headers
SECURITY_HSTS_ENABLED=false
SECURITY_HSTS_MAX_AGE_SECONDS=31536000
SECURITY_HSTS_INCLUDE_SUBDOMAINS=true
SECURITY_HSTS_PRELOAD=false
SECURITY_TRUSTED_HOSTS=
SECURITY_CONTENT_SECURITY_POLICY=default-src 'self'; img-src 'self' data: https:; style-src 'self' 'unsafe-inline'; script-src 'self' 'unsafe-inline'; connect-src 'self' https: http:; font-src 'self' data:; object-src 'none'; base-uri 'self'; frame-ancestors 'none'
SECURITY_CONTENT_SECURITY_POLICY_REPORT_ONLY=false
SECURITY_CONTENT_SECURITY_POLICY_REPORT_URI=
SECURITY_CSP_REPORT_ENDPOINT_ENABLED=false
SECURITY_CROSS_ORIGIN_OPENER_POLICY=same-origin
SECURITY_CROSS_ORIGIN_RESOURCE_POLICY=same-origin
SECURITY_CROSS_ORIGIN_EMBEDDER_POLICY=unsafe-none
SECURITY_X_DNS_PREFETCH_CONTROL=off
REQUEST_ID_HEADER_NAME=X-Request-ID

# Rate limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_TRUST_X_FORWARDED_FOR=false
RATE_LIMIT_TRUSTED_PROXY_CIDRS=
RATE_LIMIT_GLOBAL_REQUESTS=240
RATE_LIMIT_GLOBAL_WINDOW_SECONDS=60
RATE_LIMIT_GLOBAL_AUTHENTICATED_REQUESTS=1200
RATE_LIMIT_GLOBAL_AUTHENTICATED_WINDOW_SECONDS=60
RATE_LIMIT_AUTH_REQUESTS=20
RATE_LIMIT_AUTH_WINDOW_SECONDS=60
RATE_LIMIT_AUTH_LOGIN_REQUESTS=8
RATE_LIMIT_AUTH_LOGIN_WINDOW_SECONDS=60
RATE_LIMIT_PASSWORD_RESET_REQUESTS=5
RATE_LIMIT_PASSWORD_RESET_WINDOW_SECONDS=300
RATE_LIMIT_AGRO_GENERAL_REQUESTS=40
RATE_LIMIT_AGRO_GENERAL_WINDOW_SECONDS=60
RATE_LIMIT_AGRO_AI_REQUESTS=10
RATE_LIMIT_AGRO_AI_WINDOW_SECONDS=60
RATE_LIMIT_STORAGE=memory
RATE_LIMIT_REDIS_URL=
RATE_LIMIT_REDIS_PREFIX=wr:ratelimit
RATE_LIMIT_REDIS_CONNECT_TIMEOUT_SECONDS=1.0
RATE_LIMIT_REDIS_SOCKET_TIMEOUT_SECONDS=1.0
RATE_LIMIT_REDIS_REQUIRED=false

# Observability
METRICS_ENABLED=false
METRICS_REQUIRE_PROMETHEUS_CLIENT=false
METRICS_PATH=/metrics
METRICS_BEARER_TOKEN=
WORKERS_LIST_CACHE_ENABLED=true
WORKERS_LIST_CACHE_TTL_SECONDS=20
WORKERS_LIST_CACHE_MAX_ENTRIES=500

# Audit alerting (burst detection in logs)
AUDIT_ALERT_ENABLED=true
AUDIT_ALERT_WINDOW_SECONDS=300
AUDIT_ALERT_AUTH_LOGIN_FAILED_THRESHOLD=20
AUDIT_ALERT_PASSWORD_RESET_FAILED_THRESHOLD=10
AUDIT_ALERT_AGRO_ABUSE_THRESHOLD=30

# Future Supabase/PostgreSQL wiring (inactive until filled)
SUPABASE_DB_HOST=
SUPABASE_DB_PORT=5432
SUPABASE_DB_NAME=
SUPABASE_DB_USER=
SUPABASE_DB_PASSWORD=
SUPABASE_DB_SSLMODE=require
